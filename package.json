{
  "name": "hisui-ui",
  "version": "0.1.1",
  "description": "React component registry. Ark UI + Tailwind v4 で組んだ primitive を shadcn 方式 (copy-paste) で配布する CLI.",
  "type": "module",
  "license": "MIT",
  "author": "ashunar0",
  "homepage": "https://github.com/ashunar0/hisui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashunar0/hisui.git"
  },
  "bugs": {
    "url": "https://github.com/ashunar0/hisui/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwindcss",
    "ark-ui",
    "shadcn",
    "registry",
    "cli",
    "hisui"
  ],
  "bin": {
    "hisui": "./bin/hisui.mjs"
  },
  "files": [
    "bin"
  ],
  "engines": {
